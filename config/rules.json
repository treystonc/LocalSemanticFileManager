{
  "rules": [
    {
      "name": "Finance Documents",
      "conditions": {
        "operator": "OR",
        "keywords": ["invoice", "receipt", "financial", "budget", "expense"]
      },
      "similarity_threshold": 0.80,
      "target_folder": "~/Documents/Finance",
      "auto_move": true,
      "auto_move_threshold": 0.90
    },
    {
      "name": "Python Coding",
      "conditions": {
        "operator": "AND",
        "keywords": ["python", "code"]
      },
      "similarity_threshold": 0.75,
      "target_folder": "~/Documents/Coding/Python",
      "auto_move": false,
      "auto_move_threshold": 0.85
    },
    {
      "name": "Work Documents",
      "conditions": {
        "operator": "OR",
        "keywords": ["report", "meeting", "presentation", "project"]
      },
      "similarity_threshold": 0.75,
      "target_folder": "~/Documents/Work",
      "auto_move": false,
      "auto_move_threshold": 0.85
    },
    {
      "name": "Personal",
      "conditions": {
        "operator": "OR",
        "keywords": ["personal", "private", "family"]
      },
      "similarity_threshold": 0.80,
      "target_folder": "~/Documents/Personal",
      "auto_move": true,
      "auto_move_threshold": 0.85
    }
  ],
  "defaults": {
    "auto_move": false,
    "auto_move_threshold": 0.85
  }
}
